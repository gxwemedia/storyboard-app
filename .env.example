# GPT-5.4 API 配置
VITE_AI_BASE_URL=https://gmn.chuangzuoli.com
VITE_AI_API_KEY=your-api-key-here
VITE_AI_MODEL=gpt-5.4

# API 格式：chat (/v1/chat/completions) 或 responses (/v1/responses)
# 根据API提供商要求选择正确的格式
VITE_AI_WIRE_API=responses

# Gemini 图片生成配置（Stage 02 概念设定）
VITE_IMAGE_AI_BASE_URL=https://yunwu.ai
VITE_IMAGE_AI_API_KEY=your-gemini-image-key-here
VITE_IMAGE_AI_MODEL=gemini-3.1-flash-image-preview
VITE_IMAGE_AI_ASPECT_RATIO=16:9
VITE_IMAGE_AI_SIZE=1K
